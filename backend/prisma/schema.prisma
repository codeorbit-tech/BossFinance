generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  username          String         @unique
  password          String
  name              String
  role              String         @default("EMPLOYEE")
  email             String?
  phone             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  auditLogs         AuditLog[]     @relation("AuditUser")
  customersCreated  Customer[]     @relation("CustomerCreator")
  loansCreated      Loan[]         @relation("LoanCreator")
  notificationsSent Notification[] @relation("NotificationSender")
}

model Customer {
  id            String         @id @default(cuid())
  customerId    String         @unique
  name          String
  phone         String?
  email         String?
  address       String?
  aadhaar       String?
  pan           String?
  dateOfBirth   DateTime?
  occupation    String?
  status        String         @default("PENDING")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdById   String?
  bankAccount   String?
  bankIfsc      String?
  bankName      String?
  auditLogs     AuditLog[]
  createdBy     User?          @relation("CustomerCreator", fields: [createdById], references: [id])
  loans         Loan[]
  notifications Notification[]
}

model Loan {
  id                String        @id @default(cuid())
  customerId        String
  loanType          String
  amount            Float
  totalPaid         Float         @default(0)
  currentBalance    Float         @default(0)
  tenure            Int
  interestRate      Float         @default(0)
  emi               Float         @default(0)
  frequency         String        @default("MONTHLY")
  purpose           String?
  guarantorName     String?
  guarantorPhone    String?
  collateralDetails String?
  status            String        @default("PENDING")
  approvedAt        DateTime?
  disbursedAt       DateTime?
  nextDueDate       DateTime?
  pdfUrl            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String?
  queryDescription  String?
  fullData                String?
  razorpayPlanId          String?
  razorpaySubscriptionId  String?       @unique
  subscriptionStatus      String?
  subscriptionShortUrl    String?
  installments            Installment[]
  createdBy               User?         @relation("LoanCreator", fields: [createdById], references: [id])
  customer                Customer      @relation(fields: [customerId], references: [id])
  repayments              Repayment[]
}

model Repayment {
  id                 String   @id @default(cuid())
  loanId             String
  customerId         String
  amount             Float
  interestComponent  Float    @default(0)
  principalComponent Float    @default(0)
  penaltyComponent   Float    @default(0)
  paymentType        String   @default("EMI")
  method             String
  status             String   @default("SUCCESS")
  transactionId      String?  @unique
  paidAt             DateTime @default(now())
  createdAt          DateTime @default(now())
  collectedById      String?
  verifiedById       String?
  loan               Loan     @relation(fields: [loanId], references: [id])
}

model Installment {
  id                  String    @id @default(cuid())
  loanId              String
  installmentNumber   Int
  dueDate             DateTime
  expectedAmount      Float
  amountPaid          Float     @default(0)
  interestPaid        Float     @default(0)
  penaltyPaid         Float     @default(0)
  penalInterest       Float     @default(0)
  totalRemaining      Float
  balanceAfterPayment Float
  status              String    @default("UPCOMING")
  paidAt              DateTime?
  method              String?
  lastPenaltyUpdate   DateTime?
  razorpayPaymentId   String?
  failureReason       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  loan                Loan      @relation(fields: [loanId], references: [id])
}

model Notification {
  id         String    @id @default(cuid())
  customerId String
  channel    String    @default("SMS")
  template   String    @default("CUSTOM")
  message    String
  status     String    @default("PENDING")
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  sentById   String?
  sentBy     User?     @relation("NotificationSender", fields: [sentById], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  customerId  String
  field       String
  oldValue    String
  newValue    String
  createdAt   DateTime @default(now())
  changedById String?
  changedBy   User?    @relation("AuditUser", fields: [changedById], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  category    String
  description String
  amount      Float
  period      String   @default("ONE_TIME")
  addedBy     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique
  name      String
  type      String   @default("NATIONAL")
  state     String   @default("ALL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Investment {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  type        String
  description String?
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
